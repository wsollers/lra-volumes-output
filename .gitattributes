* text=auto

# Source, prose, and TeX stay LF across platforms.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.tex text eol=lf
*.bib text eol=lf
*.sty text eol=lf
*.cls text eol=lf
*.lean text eol=lf
*.cpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.c text eol=lf
*.hpp text eol=lf
*.hh text eol=lf
*.hxx text eol=lf
*.h text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Windows command files stay CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary artifacts.
*.pdf binary -diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
